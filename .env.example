# ================================================================
# DATABASE & INFRA
# ================================================================
DATABASE_URL=postgresql+asyncpg://ragcheck:ragcheck_dev@postgres:5432/ragcheck
DATABASE_URL_SYNC=postgresql://ragcheck:ragcheck_dev@postgres:5432/ragcheck
REDIS_URL=redis://redis:6379/0
UPLOAD_DIR=/uploads
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/1
EVAL_CONCURRENCY=5

# ================================================================
# PROFIL TESTARE — GRATUIT ($0)
# Obtine Gemini key: https://aistudio.google.com/apikey
# ================================================================
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_MODEL_CHEAP=gemini-2.0-flash
GEMINI_API_KEY=your_free_gemini_key_here

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_LOCAL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384
# ATENTIE: Schimbarea EMBEDDING_DIMENSIONS e DESTRUCTIVA!
# Necesita: migrare noua + stergere chunks + re-procesare documente + rebuild index

