# RAG Checker Configuration
# Copy to .env and fill in your values

APP_MODE=server  # "server" for Docker, "desktop" for .exe

# Database
DATABASE_URL=postgresql+asyncpg://ragcheck:ragcheck_dev@postgres:5432/ragcheck
DATABASE_URL_SYNC=postgresql://ragcheck:ragcheck_dev@postgres:5432/ragcheck
# For Neon cloud: postgresql+asyncpg://user:pass@ep-name.neon.tech/db
# ATENTIE: Schimbarea EMBEDDING_DIMENSIONS dupa ce exista date = re-embed tot

# File Storage
UPLOAD_DIR=/uploads

# LLM
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_MODEL_CHEAP=gemini-2.0-flash
GEMINI_API_KEY=your_key_from_aistudio_google_com

# Embeddings
EMBEDDING_PROVIDER=local  # "fastembed" (desktop), "local" (server), "openai" (production)
EMBEDDING_MODEL_LOCAL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384

# CORS (for development with separate frontend)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
